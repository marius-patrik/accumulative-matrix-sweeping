{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ams.local/schemas/manifest.schema.json",
  "title": "AMS Model Package Manifest",
  "description": "Structural schema for an AMS package. Coverage, overlap, alias, hash, and codec expansion rules also require semantic validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "format_version",
    "package_id",
    "content_root",
    "graph",
    "model",
    "storage_objects",
    "tensors",
    "required_features",
    "integrity",
    "provenance"
  ],
  "properties": {
    "schema_id": {
      "const": "ams.model.manifest"
    },
    "format_version": {
      "$ref": "#/$defs/versionPair"
    },
    "package_id": {
      "$ref": "#/$defs/identifier"
    },
    "content_root": {
      "$ref": "#/$defs/hash"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 128
    },
    "required_features": {
      "type": "array",
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "optional_features": {
      "type": "array",
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "content_hash",
        "ir_version",
        "entry_points",
        "required_operators"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8192
        },
        "content_hash": {
          "$ref": "#/$defs/hash"
        },
        "ir_version": {
          "$ref": "#/$defs/semver"
        },
        "entry_points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1024,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "required_operators": {
          "type": "array",
          "maxItems": 1000000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op_name",
              "schema_version"
            ],
            "properties": {
              "op_name": {
                "$ref": "#/$defs/identifier"
              },
              "schema_version": {
                "$ref": "#/$defs/semver"
              },
              "plugin_id": {
                "$ref": "#/$defs/identifier"
              }
            }
          }
        },
        "guards_hash": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture",
        "configuration",
        "default_dtype"
      ],
      "properties": {
        "architecture": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "configuration": {
          "type": "object",
          "maxProperties": 100000,
          "additionalProperties": true
        },
        "default_dtype": {
          "$ref": "#/$defs/dtype"
        },
        "tokenizer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "uri",
            "content_hash",
            "format"
          ],
          "properties": {
            "uri": {
              "type": "string",
              "maxLength": 8192
            },
            "content_hash": {
              "$ref": "#/$defs/hash"
            },
            "format": {
              "type": "string",
              "maxLength": 256
            }
          }
        },
        "generation_assets": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "uri",
              "content_hash"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/identifier"
              },
              "uri": {
                "type": "string",
                "maxLength": 8192
              },
              "content_hash": {
                "$ref": "#/$defs/hash"
              }
            }
          }
        }
      }
    },
    "storage_objects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "object_id",
          "uri",
          "size_bytes",
          "alignment_bytes",
          "content_hash",
          "immutable",
          "kind"
        ],
        "properties": {
          "object_id": {
            "$ref": "#/$defs/identifier"
          },
          "uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8192
          },
          "size_bytes": {
            "$ref": "#/$defs/positiveInt"
          },
          "alignment_bytes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1073741824
          },
          "content_hash": {
            "$ref": "#/$defs/hash"
          },
          "immutable": {
            "type": "boolean"
          },
          "kind": {
            "enum": [
              "tensor_data",
              "metadata",
              "graph",
              "tokenizer",
              "journal",
              "pack",
              "other"
            ]
          },
          "compression": {
            "$ref": "#/$defs/codec"
          }
        }
      }
    },
    "tensors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tensor_id",
          "tensor_class",
          "shape",
          "logical_dtype",
          "byte_order",
          "immutable",
          "layouts"
        ],
        "properties": {
          "tensor_id": {
            "$ref": "#/$defs/identifier"
          },
          "tensor_class": {
            "enum": [
              "parameter",
              "constant",
              "activation_template",
              "kv_state",
              "gradient",
              "optimizer",
              "output",
              "other"
            ]
          },
          "shape": {
            "$ref": "#/$defs/shape"
          },
          "logical_dtype": {
            "$ref": "#/$defs/dtype"
          },
          "custom_dtype_id": {
            "$ref": "#/$defs/identifier"
          },
          "byte_order": {
            "enum": [
              "little",
              "big",
              "not_applicable"
            ]
          },
          "strides": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "integer",
              "minimum": -9223372036854775808,
              "maximum": 9223372036854775807
            }
          },
          "storage_offset_elements": {
            "$ref": "#/$defs/uint"
          },
          "immutable": {
            "type": "boolean"
          },
          "version_root": {
            "$ref": "#/$defs/identifier"
          },
          "alias_of": {
            "$ref": "#/$defs/identifier"
          },
          "view": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "identity",
                  "reshape",
                  "transpose",
                  "slice",
                  "as_strided"
                ]
              },
              "parameters": {
                "$ref": "#/$defs/extensions"
              }
            },
            "required": [
              "kind"
            ]
          },
          "layouts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1024,
            "items": {
              "$ref": "#/$defs/layout"
            }
          },
          "extensions": {
            "$ref": "#/$defs/extensions"
          }
        }
      }
    },
    "mutable_roots": {
      "type": "array",
      "maxItems": 1000000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "root_id",
          "version",
          "record_uri",
          "record_hash"
        ],
        "properties": {
          "root_id": {
            "$ref": "#/$defs/identifier"
          },
          "version": {
            "$ref": "#/$defs/uint"
          },
          "record_uri": {
            "type": "string",
            "maxLength": 8192
          },
          "record_hash": {
            "$ref": "#/$defs/hash"
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_algorithm",
        "canonicalization"
      ],
      "properties": {
        "hash_algorithm": {
          "enum": [
            "sha256",
            "sha512",
            "blake3"
          ]
        },
        "canonicalization": {
          "enum": [
            "ams.canonical-json.v1",
            "ams.canonical-binary.v1"
          ]
        },
        "merkle_root": {
          "$ref": "#/$defs/hash"
        },
        "signatures": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "algorithm",
              "key_id",
              "signature_uri"
            ],
            "properties": {
              "algorithm": {
                "enum": [
                  "ed25519",
                  "ecdsa-p256",
                  "rsa-pss-sha256",
                  "custom"
                ]
              },
              "key_id": {
                "type": "string",
                "maxLength": 512
              },
              "signature_uri": {
                "type": "string",
                "maxLength": 8192
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "tool_version",
        "source_artifacts",
        "configuration_hash"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "maxLength": 512
        },
        "tool_version": {
          "$ref": "#/$defs/semver"
        },
        "source_artifacts": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "uri",
              "content_hash"
            ],
            "properties": {
              "uri": {
                "type": "string",
                "maxLength": 8192
              },
              "content_hash": {
                "$ref": "#/$defs/hash"
              },
              "license": {
                "type": "string",
                "maxLength": 1024
              }
            }
          }
        },
        "configuration_hash": {
          "$ref": "#/$defs/hash"
        },
        "command_digest": {
          "$ref": "#/$defs/hash"
        },
        "licenses": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "string",
            "maxLength": 1024
          }
        }
      }
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    }
  },
  "$defs": {
    "uint": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9223372036854775807
    },
    "positiveInt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9223372036854775807
    },
    "hash": {
      "type": "string",
      "pattern": "^(sha256|sha512|blake3):[0-9a-f]+$",
      "maxLength": 1024
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,511}$",
      "maxLength": 512
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "maxLength": 128
    },
    "versionPair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "major",
        "minor"
      ],
      "properties": {
        "major": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "minor": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    },
    "shape": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/uint"
      }
    },
    "dtype": {
      "type": "string",
      "enum": [
        "bool",
        "uint8",
        "int8",
        "uint16",
        "int16",
        "uint32",
        "int32",
        "uint64",
        "int64",
        "float8_e4m3fn",
        "float8_e5m2",
        "float16",
        "bfloat16",
        "float32",
        "float64",
        "complex64",
        "complex128",
        "int2_grouped",
        "int3_grouped",
        "int4_grouped",
        "int8_grouped",
        "custom"
      ]
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9.-]{1,127}$"
      },
      "additionalProperties": true,
      "maxProperties": 256
    },
    "byteRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "offset",
        "length",
        "checksum"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "offset": {
          "$ref": "#/$defs/uint"
        },
        "length": {
          "$ref": "#/$defs/positiveInt"
        },
        "checksum": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "codec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "lossless",
        "max_decoded_bytes"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "lossless": {
          "type": "boolean"
        },
        "max_decoded_bytes": {
          "$ref": "#/$defs/positiveInt"
        },
        "parameters": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "chunk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chunk_id",
        "range",
        "logical_origin",
        "logical_extent",
        "encoded_bytes",
        "decoded_bytes"
      ],
      "properties": {
        "chunk_id": {
          "$ref": "#/$defs/identifier"
        },
        "range": {
          "$ref": "#/$defs/byteRange"
        },
        "logical_origin": {
          "$ref": "#/$defs/shape"
        },
        "logical_extent": {
          "$ref": "#/$defs/shape"
        },
        "encoded_bytes": {
          "$ref": "#/$defs/positiveInt"
        },
        "decoded_bytes": {
          "$ref": "#/$defs/positiveInt"
        },
        "padding_bytes": {
          "$ref": "#/$defs/uint"
        },
        "codec_override": {
          "$ref": "#/$defs/codec"
        },
        "sparse_default": {
          "type": "number"
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout_id",
        "layout_version",
        "complete",
        "tile_shape",
        "alignment_bytes",
        "chunks"
      ],
      "properties": {
        "layout_id": {
          "$ref": "#/$defs/identifier"
        },
        "layout_version": {
          "$ref": "#/$defs/semver"
        },
        "backend_tags": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "type": "string",
            "maxLength": 256
          }
        },
        "complete": {
          "type": "boolean"
        },
        "tile_shape": {
          "$ref": "#/$defs/shape"
        },
        "alignment_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1073741824
        },
        "storage_dtype": {
          "$ref": "#/$defs/dtype"
        },
        "codec": {
          "$ref": "#/$defs/codec"
        },
        "chunks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100000000,
          "items": {
            "$ref": "#/$defs/chunk"
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  }
}
